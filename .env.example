# ── AI Keys ──────────────────────────────────────────────────────────────────
# Anthropic (Claude) — https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-DEIN-KEY-HIER

# OpenAI (Whisper Transkription) — https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-DEIN-KEY-HIER

# Google AI (Gemini) — https://aistudio.google.com/apikey → Create API Key
GOOGLE_API_KEY=AIzaSy-DEIN-KEY-HIER

# Fal.ai (Imagen4 Bilder + Veo3 Videos) — https://fal.ai/dashboard/keys
FAL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxx

# ── Datenbank (Neon PostgreSQL) ──────────────────────────────────────────────
# Kostenlos erstellen: https://neon.tech → Create Project → Connection String kopieren
DATABASE_URL=postgresql://neondb_owner:PASSWORT@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Vertex AI (Google Cloud — für Imagen Bildgenerierung) ────────────────────
# Google Cloud Console: https://console.cloud.google.com → Projekt erstellen → Vertex AI API aktivieren
GOOGLE_CLOUD_PROJECT=deine-projekt-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Auth (NextAuth) ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Secret generieren: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_DEIN-KEY-HIER
EMAIL_FROM=Video Creator <noreply@deine-domain.com>

# ── Admin ────────────────────────────────────────────────────────────────────
# Standard-Admin: admin@herr.tech — wird beim ersten Login automatisch angelegt
# Du kannst auch deine eigene E-Mail eintragen
ADMIN_EMAIL=admin@herr.tech
NEXT_PUBLIC_ADMIN_EMAIL=admin@herr.tech

# ── Optional: Google OAuth ──────────────────────────────────────────────────
# Falls du Google Login willst: https://console.cloud.google.com → APIs & Dienste → Anmeldedaten
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
